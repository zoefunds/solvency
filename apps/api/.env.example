# OKX Payment SDK seller credentials (required in production)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Agentic Wallet public EVM receiving address (payment recipient)
PAY_TO=

# Optional price overrides (USD per call)
PRICE_SIMULATE_USD=
PRICE_VALUATE_USD=

# Optional RPC overrides (free public defaults are used otherwise)
XLAYER_RPC_URL=
ETH_RPC_URL=

PORT=4000
